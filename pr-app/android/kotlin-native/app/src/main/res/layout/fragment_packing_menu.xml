<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:background="#F1F5F9">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#1E3A5F" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="48dp" android:paddingBottom="28dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">

                <ImageView android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp" android:padding="6dp" android:src="@android:drawable/ic_menu_revert" app:tint="#FFFFFF" />

                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Packing" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />

                <ImageView android:id="@+id/btn_home" android:layout_width="40dp" android:layout_height="40dp" android:padding="6dp" android:src="@android:drawable/ic_menu_compass" app:tint="#FFFFFF" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="HANDLING UNITS" android:textColor="#BBDEFB" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1" android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Menu tiles -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="20dp">

            <!-- HU Transfer tile -->
            <LinearLayout android:id="@+id/tile_hu_transfer" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:padding="20dp" android:elevation="2dp" android:gravity="center_vertical" android:layout_marginBottom="12dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground">

                <LinearLayout android:layout_width="56dp" android:layout_height="56dp" android:background="#FCE4EC" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="↔" android:textSize="22sp" android:textColor="#C2185B" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HU to HU Transfer" android:textSize="16sp" android:textStyle="bold" android:textColor="#1E3A5F" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan source HU → destination HU to repack" android:textSize="12sp" android:textColor="#64748B" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Pack Product tile -->
            <LinearLayout android:id="@+id/tile_pack_product" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:padding="20dp" android:elevation="2dp" android:gravity="center_vertical" android:layout_marginBottom="12dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground">

                <LinearLayout android:layout_width="56dp" android:layout_height="56dp" android:background="#E3F2FD" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="📦" android:textSize="22sp" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Pack Product to HU" android:textSize="16sp" android:textStyle="bold" android:textColor="#1E3A5F" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Scan product, confirm qty, pack into HU" android:textSize="12sp" android:textColor="#64748B" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Create HU tile -->
            <LinearLayout android:id="@+id/tile_create_hu" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#FFFFFF" android:padding="20dp" android:elevation="2dp" android:gravity="center_vertical" android:layout_marginBottom="12dp" android:clickable="true" android:focusable="true" android:foreground="?attr/selectableItemBackground">

                <LinearLayout android:layout_width="56dp" android:layout_height="56dp" android:background="#E8F5E9" android:gravity="center">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="＋" android:textSize="22sp" android:textColor="#2E7D32" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create HU" android:textSize="16sp" android:textStyle="bold" android:textColor="#1E3A5F" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Create a new empty handling unit" android:textSize="12sp" android:textColor="#64748B" android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="#0F172A">

    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/header_layout" android:layout_width="match_parent" android:layout_height="64dp" android:background="#1E293B" android:elevation="4dp">

        <ImageView android:id="@+id/btn_back" android:layout_width="48dp" android:layout_height="48dp" android:padding="12dp" android:src="@android:drawable/ic_menu_revert" app:tint="#F8FAFC" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/text_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GI Against STO" android:textSize="18sp" android:textStyle="bold" android:textColor="#F1F5F9" app:layout_constraintStart_toEndOf="@id/btn_back" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView android:id="@+id/text_error" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" android:background="#450A0A" android:textColor="#FCA5A5" android:textSize="13sp" android:padding="12dp" android:gravity="center"/>

    <TextView android:id="@+id/text_success" android:layout_width="match_parent" android:layout_height="wrap_content" android:visibility="gone" android:background="#052E16" android:textColor="#86EFAC" android:textSize="13sp" android:padding="12dp" android:gravity="center"/>

    <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" android:layout_gravity="center_horizontal"/>

    <ScrollView android:id="@+id/layout_filter" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true" android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Search Criteria" android:textSize="22sp" android:textStyle="bold" android:textColor="#F8FAFC" android:layout_marginBottom="24dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STO NUMBER" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
            <EditText android:id="@+id/input_sto_number" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 4500000061" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark" android:layout_marginBottom="20dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SUPPLYING PLANT" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
            <EditText android:id="@+id/input_supplying_plant" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 10UK" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark" android:layout_marginBottom="20dp"/>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SUPPLIER" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
            <EditText android:id="@+id/input_supplier" android:layout_width="match_parent" android:layout_height="48dp" android:hint="Supplier number" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark" android:layout_marginBottom="20dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="24dp">
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DATE FROM" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                    <EditText android:id="@+id/input_date_from" android:layout_width="match_parent" android:layout_height="48dp" android:hint="YYYY-MM-DD" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="date" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_dark"/>
                </LinearLayout>
                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DATE TO" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                    <EditText android:id="@+id/input_date_to" android:layout_width="match_parent" android:layout_height="48dp" android:hint="YYYY-MM-DD" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="date" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_dark"/>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.button.MaterialButton android:id="@+id/btn_search" android:layout_width="match_parent" android:layout_height="52dp" android:text="Search STOs" android:textSize="16sp" style="@style/Widget.MaterialComponents.Button"/>
        </LinearLayout>
    </ScrollView>

    <LinearLayout android:id="@+id/layout_list" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:visibility="gone" android:orientation="vertical">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="8dp" android:paddingBottom="4dp" android:gravity="center_vertical">
            <TextView android:id="@+id/text_result_count" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:textSize="12sp" android:textColor="#94A3B8"/>
            <com.google.android.material.button.MaterialButton android:id="@+id/btn_change_filters" android:layout_width="wrap_content" android:layout_height="36dp" android:text="Change Filters" android:textSize="11sp" style="@style/Widget.MaterialComponents.Button.TextButton"/>
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView android:id="@+id/recycler_stos" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:clipToPadding="false" android:paddingStart="12dp" android:paddingEnd="12dp" android:paddingBottom="80dp"/>
    </LinearLayout>

</LinearLayout>

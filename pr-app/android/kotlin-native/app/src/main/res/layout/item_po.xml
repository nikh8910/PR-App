<?xml version="1.0" encoding="utf-8"?>
<!-- Glass Card Layout -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginVertical="6dp" android:background="@drawable/bg_menu_card" android:padding="16dp" android:elevation="0dp">

    <!-- Blue Text highlight for IDs, matching Web -->
    <TextView android:id="@+id/text_po_number" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4500000001" android:textStyle="bold" android:textColor="#3B82F6" android:textSize="18sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" />

    <TextView android:id="@+id/text_supplier" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Supplier Name" android:textSize="14sp" android:textStyle="bold" android:textColor="#94A3B8" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/text_po_number" android:layout_marginTop="6dp" />

    <TextView android:id="@+id/text_date" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2023-10-27" android:textSize="12sp" android:textColor="#E2E8F0" app:layout_constraintEnd_toStartOf="@id/icon_chevron" app:layout_constraintTop_toTopOf="parent" android:layout_marginEnd="12dp" />

    <!-- Web-app styling chevron right icon -->
    <ImageView android:id="@+id/icon_chevron" android:layout_width="20dp" android:layout_height="20dp" android:src="@android:drawable/ic_media_play" app:tint="#475569" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

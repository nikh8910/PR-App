<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/slate_50">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_header_curved" android:paddingTop="48dp" android:paddingBottom="24dp" android:paddingHorizontal="24dp" android:elevation="8dp">

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">

            <ImageButton android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp" android:layout_gravity="start|center_vertical" android:background="@drawable/bg_icon_button" android:src="@android:drawable/ic_media_previous" app:tint="@color/white" />
        </FrameLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">

            <TextView android:id="@+id/tv_pr_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="#PRNumber" android:textColor="@color/white" android:textSize="28sp" android:textStyle="bold" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PURCHASE REQUISITION DETAILS" android:textColor="#BFDBFE" android:textSize="14sp" android:textStyle="bold" android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingHorizontal="16dp" android:paddingVertical="12dp" android:gravity="center_vertical">

        <Button android:id="@+id/btn_create_po" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="Create PO" android:textSize="14sp" android:textAllCaps="false" android:textStyle="bold" android:background="@drawable/bg_button_primary" app:backgroundTint="@color/brand_lime" android:textColor="@color/white" android:layout_marginEnd="8dp"/>

        <Button android:id="@+id/btn_add_item" android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1" android:text="Add Item" android:textSize="14sp" android:textAllCaps="false" android:textStyle="bold" android:background="@drawable/bg_button_primary" app:backgroundTint="@color/brand_light_blue" android:textColor="@color/white" android:layout_marginStart="8dp"/>
    </LinearLayout>

    <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginTop="32dp" android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/rv_pr_items" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:clipToPadding="false" android:paddingHorizontal="16dp" android:paddingTop="8dp" android:paddingBottom="80dp" />
</LinearLayout>

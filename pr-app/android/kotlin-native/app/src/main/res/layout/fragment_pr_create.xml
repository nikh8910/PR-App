<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/slate_50">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_header_curved" android:paddingTop="48dp" android:paddingBottom="24dp" android:paddingHorizontal="24dp" android:elevation="8dp">

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">

            <ImageButton android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp" android:layout_gravity="start|center_vertical" android:background="@drawable/bg_icon_button" android:src="@android:drawable/ic_media_previous" app:tint="@color/white" />
        </FrameLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">

            <TextView android:id="@+id/tv_form_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CREATE PURCHASE REQUISITION" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:textAlignment="center" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

            <!-- PR Header Fields (Hidden if adding item to existing PR) -->
            <LinearLayout android:id="@+id/layout_pr_header" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginBottom="16dp">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Header Details" android:textColor="@color/brand_blue" android:textStyle="bold" android:layout_marginBottom="8dp"/>

                <EditText android:id="@+id/et_pr_description" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="PR Description (Optional)" android:paddingHorizontal="16dp" android:textColor="@color/slate_800" android:layout_marginBottom="12dp" />
            </LinearLayout>

            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Item Details" android:textColor="@color/brand_blue" android:textStyle="bold" android:layout_marginBottom="8dp"/>

            <!-- Material with Scan -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_material" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="Material ID" android:paddingStart="16dp" android:paddingEnd="48dp" android:textColor="@color/slate_800" android:inputType="textCapCharacters" />
                <ImageButton android:id="@+id/btn_scan_material" android:layout_width="48dp" android:layout_height="48dp" android:layout_gravity="end|center_vertical" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_camera" app:tint="@color/brand_blue" />
            </FrameLayout>

            <EditText android:id="@+id/et_short_text" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="Short Text (Required if no Material)" android:paddingHorizontal="16dp" android:textColor="@color/slate_800" android:layout_marginBottom="12dp" />

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_quantity" android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="Quantity" android:inputType="numberDecimal" android:paddingHorizontal="16dp" android:textColor="@color/slate_800" android:layout_marginEnd="8dp" />
                <EditText android:id="@+id/et_uom" android:layout_width="80dp" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="UoM" android:text="EA" android:inputType="textCapCharacters" android:paddingHorizontal="16dp" android:textColor="@color/slate_800" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp">
                <EditText android:id="@+id/et_plant" android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="Plant Code" android:text="1110" android:inputType="number" android:paddingHorizontal="16dp" android:textColor="@color/slate_800" android:layout_marginEnd="8dp"/>
                <EditText android:id="@+id/et_price" android:layout_width="0dp" android:layout_weight="1" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="Valuation Price" android:text="0.00" android:inputType="numberDecimal" android:paddingHorizontal="16dp" android:textColor="@color/slate_800" />
            </LinearLayout>

            <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginVertical="16dp" android:visibility="gone" />

            <Button android:id="@+id/btn_submit" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="16dp" android:text="Submit" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:background="@drawable/bg_button_primary" app:backgroundTint="@color/brand_blue" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>

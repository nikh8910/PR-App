<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:background="#F1F5F9">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#1E3A5F" android:orientation="vertical" android:paddingStart="16dp" android:paddingEnd="16dp" android:paddingTop="48dp" android:paddingBottom="28dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
                <ImageView android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp" android:padding="6dp" android:src="@android:drawable/ic_menu_revert" app:tint="#FFFFFF" />
                <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="Create HU" android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold" />
                <ImageView android:id="@+id/btn_home" android:layout_width="40dp" android:layout_height="40dp" android:padding="6dp" android:src="@android:drawable/ic_menu_compass" app:tint="#FFFFFF" />
            </LinearLayout>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center" android:text="NEW HANDLING UNIT" android:textColor="#BBDEFB" android:textSize="11sp" android:textStyle="bold" android:letterSpacing="0.1" android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">

            <!-- Error / Success banners -->
            <TextView android:id="@+id/text_error" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#FFEBEE" android:padding="12dp" android:textColor="#C62828" android:textSize="12sp" android:visibility="gone" android:layout_marginBottom="8dp" />
            <TextView android:id="@+id/text_success" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="#E8F5E9" android:padding="12dp" android:textColor="#2E7D32" android:textSize="12sp" android:visibility="gone" android:layout_marginBottom="8dp" />

            <!-- Created HU banner (shows after creation) -->
            <LinearLayout android:id="@+id/layout_created_hu" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#E8F5E9" android:padding="16dp" android:gravity="center" android:layout_marginBottom="12dp" android:visibility="gone">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HU Created" android:textSize="13sp" android:textStyle="bold" android:textColor="#2E7D32" />
                <TextView android:id="@+id/text_created_hu_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textSize="26sp" android:textStyle="bold" android:textColor="#1E3A5F" android:fontFamily="monospace" android:layout_marginTop="4dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="You can now pack products into this HU" android:textSize="11sp" android:textColor="#64748B" android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Form card -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="#FFFFFF" android:padding="16dp" android:elevation="2dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WAREHOUSE *" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" android:letterSpacing="0.1" android:layout_marginBottom="4dp" />
                <Spinner android:id="@+id/spinner_warehouse" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PACKAGING MATERIAL *" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" android:letterSpacing="0.1" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" app:endIconMode="clear_text" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/input_packaging_material" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Scan or type material" android:inputType="textCapCharacters" android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORAGE BIN *" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" android:letterSpacing="0.1" android:layout_marginBottom="4dp" />
                <com.google.android.material.textfield.TextInputLayout android:layout_width="match_parent" android:layout_height="wrap_content" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" app:endIconMode="clear_text" android:layout_marginBottom="12dp">
                    <com.google.android.material.textfield.TextInputEditText android:id="@+id/input_storage_bin" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Scan or type bin" android:inputType="textCapCharacters" android:textSize="14sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PLANT (OPTIONAL)" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" android:letterSpacing="0.1" android:layout_marginBottom="4dp" />
                <Spinner android:id="@+id/spinner_plant" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:layout_marginBottom="12dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORAGE LOCATION (OPTIONAL)" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" android:letterSpacing="0.1" android:layout_marginBottom="4dp" />
                <Spinner android:id="@+id/spinner_storage_loc" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:layout_marginBottom="12dp"/>

                <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:visibility="gone" android:layout_marginBottom="8dp" />

                <Button android:id="@+id/btn_create" android:layout_width="match_parent" android:layout_height="52dp" android:text="Create Handling Unit" android:backgroundTint="#1E3A5F" android:textColor="#FFFFFF" android:textStyle="bold" android:textSize="15sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>

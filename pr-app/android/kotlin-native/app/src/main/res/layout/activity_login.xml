<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:fillViewport="true" android:background="#0F172A">

    <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_glass_card" android:elevation="8dp" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent">

            <!-- Logo Area -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ODS mWH" android:textSize="24sp" android:textStyle="bold" android:textColor="#E2E8F0" android:layout_gravity="center_horizontal" android:layout_marginBottom="32dp" />

            <!-- Error Message Box -->
            <LinearLayout android:id="@+id/layout_error" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:background="#337F1D1D" android:padding="12dp" android:visibility="gone" android:layout_marginBottom="24dp">

                <TextView android:id="@+id/text_error" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#FCA5A5" android:textSize="12sp" />
            </LinearLayout>

            <!-- API Endpoint Input -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="API ENDPOINT" android:textAllCaps="true" android:textStyle="bold" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>

            <EditText android:id="@+id/edit_server" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_dark" android:paddingStart="16dp" android:paddingEnd="12dp" android:textColor="#F8FAFC" android:textColorHint="#94A3B8" android:textSize="14sp" android:inputType="textUri" android:hint="https://..." android:layout_marginBottom="20dp" />

            <!-- Username Input -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="USERNAME" android:textAllCaps="true" android:textStyle="bold" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>

            <EditText android:id="@+id/edit_username" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_dark" android:paddingStart="16dp" android:paddingEnd="12dp" android:textColor="#F8FAFC" android:textColorHint="#94A3B8" android:textSize="14sp" android:inputType="text" android:hint="Username" android:layout_marginBottom="20dp" />

            <!-- Password Input -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PASSWORD" android:textAllCaps="true" android:textStyle="bold" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>

            <EditText android:id="@+id/edit_password" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_dark" android:paddingStart="16dp" android:paddingEnd="12dp" android:textColor="#F8FAFC" android:textColorHint="#94A3B8" android:textSize="14sp" android:inputType="textPassword" android:hint="Password" android:layout_marginBottom="24dp" />

            <!-- Divider -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">

                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" android:layout_gravity="center_vertical" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OR USE API KEY" android:textAllCaps="true" android:textSize="10sp" android:textStyle="bold" android:textColor="#64748B" android:background="#1E293B" android:paddingHorizontal="8dp" android:layout_gravity="center" />
            </FrameLayout>

            <!-- API Key Input -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="API KEY (SANDBOX)" android:textAllCaps="true" android:textStyle="bold" android:textColor="#64748B" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>

            <EditText android:id="@+id/edit_apikey" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_dark" android:paddingStart="16dp" android:paddingEnd="12dp" android:textColor="#F8FAFC" android:textColorHint="#94A3B8" android:textSize="14sp" android:inputType="text" android:hint="API Key" android:layout_marginBottom="32dp" />

            <!-- Sign In Button -->
            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content">

                <Button android:id="@+id/btn_login" android:layout_width="match_parent" android:layout_height="52dp" android:text="Sign In" android:textAllCaps="false" android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/bg_button_primary" app:backgroundTint="@null"/>

                <ProgressBar android:id="@+id/progress_login" android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:indeterminateTint="#FFFFFF" android:visibility="gone" android:elevation="2dp"/>
            </FrameLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:background="@drawable/bg_menu_card" android:padding="16dp" android:elevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <TextView android:id="@+id/text_material_desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Material Description" android:textColor="#F8FAFC" android:textStyle="bold" android:textSize="16sp" />

        <TextView android:id="@+id/text_material_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAT123" android:textSize="12sp" android:textColor="#3B82F6" android:textStyle="bold" android:layout_marginTop="4dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp" android:background="#0F172A" android:padding="8dp">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="DELIVERED QTY" android:textSize="10sp" android:textColor="#94A3B8" android:textStyle="bold" />

            <TextView android:id="@+id/text_delivery_qty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#E2E8F0" android:text="10 PC" />
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PUTAWAY QUANTITY" android:textColor="#64748B" android:textStyle="bold" android:textSize="10sp" android:layout_marginTop="16dp" android:layout_marginBottom="4dp" android:layout_marginStart="4dp"/>

        <EditText android:id="@+id/edit_putaway_qty" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input_dark" android:paddingHorizontal="12dp" android:textColor="#F8FAFC" android:textColorHint="#475569" android:textSize="14sp" android:inputType="numberDecimal" android:hint="0"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORAGE LOCATION" android:textColor="#64748B" android:textStyle="bold" android:textSize="10sp" android:layout_marginTop="12dp" android:layout_marginBottom="4dp" android:layout_marginStart="4dp"/>

        <EditText android:id="@+id/edit_storage_loc" android:layout_width="match_parent" android:layout_height="44dp" android:background="@drawable/bg_input_dark" android:paddingHorizontal="12dp" android:textColor="#F8FAFC" android:textColorHint="#475569" android:textSize="14sp" android:inputType="textCapCharacters" android:hint="e.g. 101D"/>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

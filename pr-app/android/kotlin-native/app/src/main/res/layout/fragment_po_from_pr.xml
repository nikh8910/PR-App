<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="@color/slate_50">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_header_curved" android:paddingTop="48dp" android:paddingBottom="24dp" android:paddingHorizontal="24dp" android:elevation="8dp">

        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="16dp">

            <ImageButton android:id="@+id/btn_back" android:layout_width="40dp" android:layout_height="40dp" android:layout_gravity="start|center_vertical" android:background="@drawable/bg_icon_button" android:src="@android:drawable/ic_media_previous" app:tint="@color/white" />
        </FrameLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">

            <TextView android:id="@+id/tv_form_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CONVERT TO PURCHASE ORDER" android:textColor="@color/white" android:textSize="20sp" android:textStyle="bold" android:textAlignment="center" />

            <TextView android:id="@+id/tv_pr_ref" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="From PR: 10000000" android:textColor="#BFDBFE" android:textSize="14sp" android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:fillViewport="true">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="24dp">

            <!-- Supplier Input -->
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="A valid Supplier ID is required to generate a Purchase Order." android:textColor="@color/slate_600" android:textSize="14sp" android:layout_marginBottom="16dp"/>

            <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="24dp">

                <EditText android:id="@+id/et_supplier" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/edit_text_bg" android:hint="Supplier ID" android:paddingStart="16dp" android:paddingEnd="48dp" android:textColor="@color/slate_800" android:inputType="number" />

                <ImageButton android:id="@+id/btn_scan_supplier" android:layout_width="48dp" android:layout_height="48dp" android:layout_gravity="end|center_vertical" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_camera" app:tint="@color/brand_blue" />
            </FrameLayout>

            <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center" android:layout_marginVertical="16dp" android:visibility="gone" />

            <Button android:id="@+id/btn_submit" android:layout_width="match_parent" android:layout_height="56dp" android:text="Convert to PO" android:textColor="@color/white" android:textSize="16sp" android:textStyle="bold" android:background="@drawable/bg_button_primary" app:backgroundTint="@color/brand_blue" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>

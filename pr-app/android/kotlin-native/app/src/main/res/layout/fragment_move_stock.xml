<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="match_parent" android:orientation="vertical" android:background="#0F172A">    <!-- bg-slate-900 -->

    <!-- Custom Top Header -->
    <androidx.constraintlayout.widget.ConstraintLayout android:id="@+id/header_layout" android:layout_width="match_parent" android:layout_height="64dp" android:background="#1E293B" android:elevation="4dp">

        <ImageView android:id="@+id/btn_back" android:layout_width="48dp" android:layout_height="48dp" android:padding="12dp" android:src="@android:drawable/ic_menu_revert" app:tint="#F8FAFC" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>

        <TextView android:id="@+id/header_title" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Move Stock" android:textSize="18sp" android:textStyle="bold" android:textColor="#F1F5F9" app:layout_constraintStart_toEndOf="@id/btn_back" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- Bottom border -->
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#334155" app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">

        <ScrollView android:layout_width="match_parent" android:layout_height="match_parent" android:padding="16dp" android:clipToPadding="false" android:paddingBottom="100dp">

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

                <!-- Source Details Card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_menu_card" android:padding="16dp" android:layout_marginBottom="16dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Source Details" android:textSize="18sp" android:textStyle="bold" android:textColor="#F8FAFC" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MATERIAL" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                    <EditText android:id="@+id/input_material" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. MAT123" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SRC PLANT" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                            <EditText android:id="@+id/input_source_plant" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 1010" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SRC SLOC" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                            <EditText android:id="@+id/input_source_sloc" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 0001" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Destination Details Card -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:background="@drawable/bg_menu_card" android:padding="16dp" android:layout_marginBottom="24dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Destination &amp; Movement" android:textSize="18sp" android:textStyle="bold" android:textColor="#F8FAFC" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MOVEMENT TYPE" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                    <Spinner android:id="@+id/spinner_movement_type" android:layout_width="match_parent" android:layout_height="48dp" android:background="@drawable/bg_input_dark" android:popupBackground="#1E293B" android:paddingStart="12dp" android:layout_marginBottom="16dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEST PLANT" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                            <EditText android:id="@+id/input_dest_plant" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 1010" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark"/>
                        </LinearLayout>

                        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="DEST SLOC" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                            <EditText android:id="@+id/input_dest_sloc" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 0002" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="text" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QUANTITY TO MOVE" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="12sp" android:layout_marginTop="16dp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                    <EditText android:id="@+id/input_qty" android:layout_width="match_parent" android:layout_height="48dp" android:hint="QTY" android:textColorHint="#475569" android:textColor="#22C55E" android:textStyle="bold" android:inputType="numberDecimal" android:paddingStart="16dp" android:paddingEnd="16dp" android:background="@drawable/bg_input_dark"/>
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <ProgressBar android:id="@+id/progress_bar" android:layout_width="wrap_content" android:layout_height="wrap_content" android:visibility="gone" android:indeterminateTint="#3B82F6" android:layout_gravity="center"/>

        <!-- Sticky Bottom Button -->
        <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:background="#0F172A" android:padding="16dp">

            <Button android:id="@+id/btn_move_stock" android:layout_width="match_parent" android:layout_height="56dp" android:text="Execute Move" android:textSize="16sp" android:textStyle="bold" android:textColor="#FFFFFF" android:background="@drawable/bg_button_primary" app:backgroundTint="@null"/>
        </FrameLayout>

    </FrameLayout>
</LinearLayout>

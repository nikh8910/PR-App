<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="12dp" android:background="@drawable/bg_menu_card" android:padding="16dp" android:elevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <TextView android:id="@+id/text_material_desc" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Material Description" android:textColor="#F8FAFC" android:textStyle="bold" android:textSize="16sp" />

        <TextView android:id="@+id/text_material_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAT123" android:textSize="12sp" android:textColor="#3B82F6" android:textStyle="bold" android:layout_marginTop="4dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp" android:background="#0F172A" android:padding="8dp">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="ORDERED QTY" android:textSize="10sp" android:textColor="#94A3B8" android:textStyle="bold" />

            <TextView android:id="@+id/text_ordered_qty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:textColor="#E2E8F0" android:text="10 PC" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="GR QUANTITY" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="10sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <EditText android:id="@+id/edit_gr_qty" android:layout_width="match_parent" android:layout_height="48dp" android:hint="QTY" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="numberDecimal" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_dark"/>
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STORAGE LOC" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="10sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <EditText android:id="@+id/edit_storage_loc" android:layout_width="match_parent" android:layout_height="48dp" android:hint="e.g. 101A" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="textCapCharacters" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_dark"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

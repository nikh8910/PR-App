<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="12dp" android:background="@drawable/bg_glass_card" android:clipToOutline="true" android:foreground="?attr/selectableItemBackground" android:padding="16dp" android:gravity="center_vertical">

    <LinearLayout android:layout_width="40dp" android:layout_height="40dp" android:background="@drawable/bg_menu_card" android:backgroundTint="#EFF6FF" android:gravity="center" android:layout_marginEnd="16dp">
        <TextView android:id="@+id/tv_item_num" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="00010" android:textColor="#2563EB" android:textSize="12sp" android:textStyle="bold" android:fontFamily="monospace" />
    </LinearLayout>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">

        <TextView android:id="@+id/tv_item_title" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Item Name" android:textColor="@color/slate_800" android:textSize="16sp" android:textStyle="bold" />

        <TextView android:id="@+id/tv_item_subtitle" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Material ID" android:textColor="@color/slate_500" android:textSize="14sp" android:layout_marginTop="2dp" />
    </LinearLayout>

    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="end">

        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:gravity="bottom">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="QTY" android:textColor="@color/slate_400" android:textSize="11sp" android:textStyle="bold" android:layout_marginEnd="4dp" />

            <TextView android:id="@+id/tv_item_qty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1" android:textColor="@color/slate_800" android:textSize="18sp" android:textStyle="bold" />

            <TextView android:id="@+id/tv_item_uom" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="EA" android:textColor="@color/slate_500" android:textSize="11sp" android:textStyle="bold" android:layout_marginStart="2dp" />
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="REQUESTED" android:textColor="@color/slate_400" android:textSize="9sp" android:textStyle="bold" android:letterSpacing="0.05" />
    </LinearLayout>

</LinearLayout>

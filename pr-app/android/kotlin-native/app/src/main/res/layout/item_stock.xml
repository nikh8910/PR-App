<?xml version="1.0" encoding="utf-8"?>
<!-- Glass Card Layout -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="4dp" android:layout_marginVertical="6dp" android:background="@drawable/bg_menu_card" android:padding="16dp" android:elevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <TextView android:id="@+id/text_material_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAT123" android:textColor="#3B82F6" android:textStyle="bold" android:textSize="18sp" />

        <TextView android:id="@+id/text_location" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plant: 1010 | Loc: 0001" android:textSize="14sp" android:textColor="#94A3B8" android:layout_marginTop="6dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="12dp" android:gravity="center_vertical">

            <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="QUANTITY" android:textColor="#64748B" android:textSize="12sp" android:textStyle="bold" />

            <TextView android:id="@+id/text_qty" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="150 PC" android:textColor="#22C55E" android:textSize="16sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

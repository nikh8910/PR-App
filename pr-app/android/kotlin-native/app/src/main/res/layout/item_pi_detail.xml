<?xml version="1.0" encoding="utf-8"?>
<!-- Glass Card Layout -->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginHorizontal="16dp" android:layout_marginVertical="6dp" android:background="@drawable/bg_menu_card" android:padding="16dp" android:elevation="0dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">

        <TextView android:id="@+id/text_material_id" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAT123" android:textColor="#3B82F6" android:textStyle="bold" android:textSize="18sp" />

        <TextView android:id="@+id/text_info" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Batch: LOT1 | Item: 001" android:textSize="14sp" android:textColor="#94A3B8" android:layout_marginTop="6dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="16dp" android:gravity="center_vertical">

            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:layout_marginEnd="8dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="COUNTED QUANTITY" android:textColor="#94A3B8" android:textStyle="bold" android:textAllCaps="true" android:textSize="10sp" android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>
                <EditText android:id="@+id/input_count_qty" android:layout_width="match_parent" android:layout_height="48dp" android:hint="QTY" android:textColorHint="#475569" android:textColor="#F8FAFC" android:inputType="numberDecimal" android:paddingStart="12dp" android:paddingEnd="12dp" android:background="@drawable/bg_input_dark"/>
            </LinearLayout>

            <Button android:id="@+id/btn_save_count" android:layout_width="wrap_content" android:layout_height="48dp" android:text="Save" android:textColor="#FFFFFF" android:background="@drawable/bg_button_primary" android:gravity="center" android:layout_marginTop="20dp" />
            <!-- align with bottom input box -->
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
